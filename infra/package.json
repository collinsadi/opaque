{
  "name": "infra",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node",
    "deploy": "hardhat ignition deploy ignition/modules/Stealth.ts",
    "deploy:local": "hardhat ignition deploy ignition/modules/Stealth.ts --network localhost",
    "deploy:base-sepolia": "hardhat ignition deploy ignition/modules/Stealth.ts --network baseSepolia",
    "deploy:paseo": "hardhat ignition deploy ignition/modules/Stealth.ts --network paseo",
    "deploy:sepolia": "hardhat ignition deploy ignition/modules/Stealth.ts --network sepolia",
    "deploy:sepolia:verify": "hardhat ignition deploy ignition/modules/Stealth.ts --network sepolia --verify",
    "deploy:tokens": "hardhat ignition deploy ignition/modules/Tokens.ts",
    "deploy:tokens:local": "hardhat ignition deploy ignition/modules/Tokens.ts --network localhost",
    "deploy:tokens:sepolia": "hardhat ignition deploy ignition/modules/Tokens.ts --network sepolia",
    "deploy:tokens:sepolia:verify": "hardhat ignition deploy ignition/modules/Tokens.ts --network sepolia --verify",
    "deploy:tokens:base-sepolia": "hardhat ignition deploy ignition/modules/Tokens.ts --network baseSepolia",
    "deploy:tokens:paseo": "hardhat ignition deploy ignition/modules/Tokens.ts --network paseo",
    "verify:sepolia": "hardhat verify --network sepolia",
    "clean": "hardhat clean",
    "deploy:scripts": "hardhat compile && tsx scripts/deploy.ts"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "ethers": "^6.13.4"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ignition": "^3.0.7",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.2",
    "@types/node": "^22.19.11",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.1.8",
    "tsx": "^4.19.2",
    "typescript": "~5.8.0",
    "viem": "^2.46.2"
  }
}
