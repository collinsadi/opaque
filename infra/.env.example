# Base Sepolia (for npm run deploy:base-sepolia)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_PRIVATE_KEY=0x...

# Optional: for deploy:local (use one of the keys from `npm run node` output)
PRIVATE_KEY=0x...

# Optional: existing Sepolia config
# SEPOLIA_RPC_URL=...
# SEPOLIA_PRIVATE_KEY=0x...
