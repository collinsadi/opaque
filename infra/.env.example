# Etherscan (for contract verification: npx hardhat verify --network sepolia <address>)
# Get one at https://etherscan.io/myapikey — same key works for Sepolia, Base, etc.
ETHERSCAN_API_KEY=

# Local deploy (default RPC when running deploy:local). Override with RPC_URL if needed.
# RPC_URL=http://127.0.0.1:8545

# Optional: for deploy:local (use one of the keys from `npx hardhat node` output)
PRIVATE_KEY=0x...

# Sepolia (for npm run deploy:sepolia)
SEPOLIA_RPC_URL=
SEPOLIA_PRIVATE_KEY=0x...

# Base Sepolia (for npm run deploy:base-sepolia)
BASE_SEPOLIA_RPC_URL=
BASE_SEPOLIA_PRIVATE_KEY=0x...

