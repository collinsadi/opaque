# Target chain for wallet/send transactions. Change this to switch networks.
# 31337 = local Hardhat node (default), 1 = Ethereum mainnet, 11155111 = Sepolia
VITE_CHAIN_ID=31337
# Optional label (e.g. localhost, mainnet) used when chain is not predefined
VITE_NETWORK=localhost

# Custom RPC URL (recommended for Sepolia/mainnet to avoid rate limits).
# If unset, public RPC for the chain is used and a console warning is shown.
# VITE_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-key

# EIP-5564 StealthAddressAnnouncer contract (per chain)
VITE_ANNOUNCER_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: Subgraph URL for announcement indexer (avoids RPC rate limits; falls back to chunked RPC if unset or fetch fails)
# VITE_SUBGRAPH_URL=https://api.studio.thegraph.com/query/.../subgraph/version/latest
