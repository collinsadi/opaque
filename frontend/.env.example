# Copy this file to .env and fill in values. Do not commit .env.

# Target chain for wallet/send transactions.
# 31337 = local Hardhat node (default), 1 = Ethereum mainnet, 11155111 = Sepolia, 420420417 = Paseo (Polkadot Hub testnet)
VITE_CHAIN_ID=31337
# Optional label (e.g. localhost, mainnet, paseo) used when chain is not predefined
VITE_NETWORK=localhost

# RPC URL for the chain (recommended to avoid rate limits).
# If unset, public RPC for the chain is used and a console warning is shown.
# VITE_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# VITE_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY

# RPC URL for Paseo (420420417). When set, used for Paseo instead of VITE_RPC_URL or the default.
# VITE_PASEO_RPC_URL=https://testnet-passet-hub-eth-rpc.polkadot.io

# EIP-5564 StealthAddressAnnouncer contract (per chain). Often set by deploy script via deployed-addresses.json.
VITE_ANNOUNCER_ADDRESS=0x0000000000000000000000000000000000000000

# Subgraph URL for announcement indexer (optional). When set, scanner uses indexer first and falls back to chunked RPC on failure.
# VITE_SUBGRAPH_URL=https://gateway.thegraph.com/api/subgraphs/id/YOUR_SUBGRAPH_ID
# VITE_SUBGRAPH_URL=https://api.studio.thegraph.com/query/.../subgraph/version/latest

# Subgraph URL for Paseo (Polkadot Hub testnet). Used when chain is 420420417; overrides VITE_SUBGRAPH_URL for that chain.
# Deploy the Paseo subgraph (subgraph/subgraph.paseo.yaml) to a self-hosted Graph Node or supported indexer, then set this.
# If unset, the scanner falls back to RPC getLogs for the announcer contract.
# VITE_POLKADOT_SUBGRAPH_URL=https://your-graph-node.com/subgraphs/name/opaque-paseo

VITE_GRAPH_AUTH=YOUR_GRAPH_AUTH_TOKEN