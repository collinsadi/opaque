# Copy this file to .env and fill in values. Do not commit .env.

# Target chain for wallet/send transactions.
# 31337 = local Hardhat node (default), 1 = Ethereum mainnet, 11155111 = Sepolia
VITE_CHAIN_ID=31337
# Optional label (e.g. localhost, mainnet) used when chain is not predefined
VITE_NETWORK=localhost

# RPC URL for the chain (recommended for Sepolia/mainnet to avoid rate limits).
# If unset, public RPC for the chain is used and a console warning is shown.
# VITE_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# VITE_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY

# EIP-5564 StealthAddressAnnouncer contract (per chain). Often set by deploy script via deployed-addresses.json.
VITE_ANNOUNCER_ADDRESS=0x0000000000000000000000000000000000000000

# Subgraph URL for announcement indexer (optional). When set, scanner uses indexer first and falls back to chunked RPC on failure.
# VITE_SUBGRAPH_URL=https://gateway.thegraph.com/api/subgraphs/id/YOUR_SUBGRAPH_ID
# VITE_SUBGRAPH_URL=https://api.studio.thegraph.com/query/.../subgraph/version/latest

VITE_GRAPH_AUTH=YOUR_GRAPH_AUTH_TOKEN